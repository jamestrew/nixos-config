{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "pr-review-toolkit@claude-code-plugins": false,
    "commit-commands@claude-code-plugins": false,
    "feature-dev@claude-code-plugins": false,
    "code-review@claude-code-plugins": false,
    "explanatory-output-style@claude-code-plugins": true,
    "learning-output-style@claude-code-plugins": false,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": false
  },
  "alwaysThinkingEnabled": true,
  "tui": "fullscreen",
  "preferredNotifChannel": "ghostty",
  "agentPushNotifEnabled": true,
  "voiceEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754663437734
  }
}
